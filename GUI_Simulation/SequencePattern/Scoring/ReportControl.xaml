<UserControl x:Class="GUI_Simulation.SequencePattern.Scoring.ReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GUI_Simulation.SequencePattern.Scoring"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d"
             d:DesignHeight="270" d:DesignWidth="500" Background="Gray">
    <Grid Margin="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <GroupBox Margin="3" Grid.Column="0">
            <GroupBox.Header>
                <TextBlock Text="{Binding information.Name}" Foreground="White"/>
            </GroupBox.Header>
            <Grid Margin="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Grid.ColumnSpan="2" Margin="2 " Header="Özet" BorderThickness="0">
                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"></TextBlock>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Margin="3,2" Header="Veri Sayıları" BorderThickness="0">
                    <Grid Margin="-3,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <TextBlock Margin="2" Grid.Column="0" Text="Toplam:"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="1" Text="{Binding TotalCount}"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="2" Text="Test:"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="3" Text="{Binding TrainingSetCount}"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="4" Text="Eklenen:"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="5" Text="{Binding NewAddedDataCount}"></TextBlock>
                    </Grid>
                </GroupBox>

                <Grid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Deneme Sayısı:" Margin="5"></TextBlock>
                    <TextBlock Grid.Column="1" Text="{Binding TestCount}" Margin="5"></TextBlock>
                </Grid>

                <GroupBox Grid.Row="3" Grid.ColumnSpan="2" Margin="3,2" Header="Doğruluk Ölçümü" BorderThickness="0">
                    <Grid Margin="-3,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock Margin="2" Grid.Column="0" Grid.Row="0" Text="Doğruluk Oranı:" Grid.RowSpan="2"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="1" Grid.Row="0" Text="{Binding information.Accuracy, StringFormat={}{0:0.000}}"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="2" Grid.Row="0" Text="Hata Oranı:"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="3" Grid.Row="0" Text="{Binding information.Error, StringFormat={}{0:0.000}}"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="0" Grid.Row="1" Text="Kesinlik:"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="1" Grid.Row="1" Text="{Binding information.Precision, StringFormat={}{0:0.000}}"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="2" Grid.Row="1" Text="Hassasiyet:"></TextBlock>
                        <TextBlock Margin="2" Grid.Column="3" Grid.Row="1" Text="{Binding information.Recall, StringFormat={}{0:0.000}}"></TextBlock>
                    </Grid>
                </GroupBox>

                <Grid Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ortalam Doğruluk:" Margin="5"></TextBlock>
                    <TextBlock Grid.Column="1" Text="{Binding information.Fscore}" Margin="5"></TextBlock>
                </Grid>
                <StackPanel Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <Button Name="btnReset" Content="Sıfırla" Margin="2" Width="75"></Button>
                    <Button Name="btnExport" Content="Aktar" Margin="2" Width="75" Click="btnExport_Click"></Button>
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Column="1" Margin="3">
            <GroupBox.Header>
                <TextBlock Text="Grafik" Foreground="White"/>
            </GroupBox.Header>
            <Grid Margin="1" Background="White">
                <oxy:PlotView x:Name="plotView" />
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
